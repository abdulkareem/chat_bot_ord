{
  "name": "hyperlocal-chat-marketplace-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "node apps/backend/src/server.js",
    "dev:worker": "wrangler dev -c apps/worker/wrangler.toml",
    "test": "node --test tests/*.test.js",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "wrangler": "^4.9.0"
  }
}
