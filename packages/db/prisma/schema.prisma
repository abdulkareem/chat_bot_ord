generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  DRIVER
  SERVICE_AGENT
  ADMIN
}

enum VendorCategory {
  SUPERMARKET
  GROCERY
  FANCY
  HOTEL
  TEA_SHOP
}

enum VehicleType {
  AUTO
  TAXI
}

enum OrderType {
  ORDER
  RIDE
  SERVICE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OnboardingType {
  VENDOR
  DRIVER
  SERVICE
}

enum OnboardingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadIntent {
  SHOPPING
  AUTO
  SERVICE
  UNKNOWN
}

enum LeadStatus {
  OPEN
  QUALIFIED
  CONVERTED
  CLOSED
}

enum SubscriptionType {
  FREE
  BASIC
  PREMIUM
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum WalletTxnType {
  CREDIT
  DEBIT
}

enum LeadEventType {
  SEARCH
  VENDOR_CLICK
  CHAT_STARTED
  ORDER_INTENT
}

model User {
  id             String   @id @default(cuid())
  name           String?
  phone          String   @unique
  role           Role
  lastLatitude   Float?
  lastLongitude  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor          Vendor?
  driver          Driver?
  serviceAgent    ServiceAgent?
  onboardingApps  OnboardingApplication[]

  customerRooms   ChatRoom[] @relation("CustomerRooms")
  sentMessages    Message[]

  initiatedOrders OrderRide[] @relation("OrderInitiator")
  leads           Lead[] @relation("LeadCustomer")

  @@index([lastLatitude, lastLongitude])
}

model Vendor {
  id                 String            @id @default(cuid())
  userId             String            @unique
  category           VendorCategory
  status             VendorStatus      @default(ACTIVE)
  latitude           Float
  longitude          Float
  isPaid             Boolean           @default(false)
  paidBoost          Int               @default(0)
  rating             Float             @default(0)
  avgResponseSeconds Int               @default(120)
  subscriptionType   SubscriptionType  @default(FREE)
  subscriptionExpiry DateTime?
  priorityScore      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRooms          ChatRoom[]
  orders             OrderRide[]
  leads              Lead[]
  promotions         VendorPromotion[]
  invoices           VendorSubscriptionInvoice[]
  paymentTxns        PaymentTransaction[]
  wallet             VendorWallet?
  walletLedger       WalletLedger[]
  leadEvents         LeadEvent[]

  @@index([latitude, longitude])
  @@index([category, status])
  @@index([status, subscriptionType, priorityScore])
}

model Driver {
  id          String      @id @default(cuid())
  userId      String      @unique
  vehicleType VehicleType
  isAvailable Boolean     @default(true)
  rating      Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRooms   ChatRoom[]
  rides       OrderRide[]
  leads       Lead[]

  @@index([vehicleType, isAvailable, rating])
}

model ServiceAgent {
  id          String   @id @default(cuid())
  userId      String   @unique
  serviceType String
  isAvailable Boolean  @default(true)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads       Lead[]
  orders      OrderRide[]

  @@index([serviceType, isAvailable, rating])
}

model OnboardingApplication {
  id          String           @id @default(cuid())
  applicantId String
  type        OnboardingType
  status      OnboardingStatus @default(PENDING)
  details     Json?
  reviewedBy  String?
  reviewNotes String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  applicant   User             @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([type, status, createdAt])
}

model Lead {
  id             String        @id @default(cuid())
  customerId     String
  intent         LeadIntent
  query          String
  status         LeadStatus    @default(OPEN)
  vendorId       String?
  driverId       String?
  serviceAgentId String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer       User          @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  vendor         Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  driver         Driver?       @relation(fields: [driverId], references: [id], onDelete: SetNull)
  serviceAgent   ServiceAgent? @relation(fields: [serviceAgentId], references: [id], onDelete: SetNull)
  events         LeadEvent[]

  @@index([customerId, createdAt])
  @@index([intent, status, createdAt])
}

model LeadEvent {
  id         String        @id @default(cuid())
  leadId     String
  vendorId   String?
  eventType  LeadEventType
  metadata   Json?
  createdAt  DateTime      @default(now())

  lead       Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vendor     Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([leadId, eventType, createdAt])
  @@index([vendorId, createdAt])
}

model ChatRoom {
  id         String     @id @default(cuid())
  customerId String
  vendorId   String?
  driverId   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer   User       @relation("CustomerRooms", fields: [customerId], references: [id], onDelete: Cascade)
  vendor     Vendor?    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  driver     Driver?    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([customerId, vendorId])
  @@index([customerId, driverId])
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  senderId   String
  message    String
  timestamp  DateTime @default(now())

  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId, timestamp])
}

model OrderRide {
  id             String        @id @default(cuid())
  type           OrderType
  status         OrderStatus   @default(PENDING)
  customerId     String
  vendorId       String?
  driverId       String?
  serviceAgentId String?
  leadId         String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  customer       User          @relation("OrderInitiator", fields: [customerId], references: [id], onDelete: Cascade)
  vendor         Vendor?       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  driver         Driver?       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  serviceAgent   ServiceAgent? @relation(fields: [serviceAgentId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([type, status])
}

model VendorPromotion {
  id           String   @id @default(cuid())
  vendorId     String
  boostPoints  Int
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean  @default(true)
  paymentTxnId String?
  createdAt    DateTime @default(now())

  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, isActive, startsAt, endsAt])
}

model VendorSubscriptionInvoice {
  id               String           @id @default(cuid())
  vendorId         String
  subscriptionType SubscriptionType
  startsAt         DateTime
  endsAt           DateTime
  amount           Float
  paymentTxnId     String?
  status           PaymentStatus    @default(PENDING)
  createdAt        DateTime         @default(now())

  vendor           Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
}

model PaymentTransaction {
  id          String        @id @default(cuid())
  vendorId    String?
  amount      Float
  currency    String        @default("INR")
  provider    String
  providerRef String
  status      PaymentStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor      Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([vendorId, status, createdAt])
  @@index([providerRef])
}

model VendorWallet {
  id           String   @id @default(cuid())
  vendorId      String   @unique
  balance       Float    @default(0)
  totalCredited Float    @default(0)
  totalDebited  Float    @default(0)
  updatedAt     DateTime @updatedAt

  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model WalletLedger {
  id          String        @id @default(cuid())
  vendorId    String
  amount      Float
  type        WalletTxnType
  reason      String
  referenceId String?
  createdAt   DateTime      @default(now())

  vendor      Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
}

model AnalyticsMetric {
  id             String   @id @default(cuid())
  metricDate     DateTime
  category       String
  searches       Int      @default(0)
  chatsStarted   Int      @default(0)
  leadsQualified Int      @default(0)
  ordersCreated  Int      @default(0)
  conversionRate Float    @default(0)
  revenue        Float    @default(0)
  createdAt      DateTime @default(now())

  @@index([metricDate, category])
  @@index([createdAt])
}
