{
  "name": "backend-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/server.js",
    "start": "prisma db push --schema ./prisma/schema.prisma && node src/server.js",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.12.6",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.20.0",
    "ws": "^8.18.0"
  }
}
